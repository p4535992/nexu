<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="false">
    <!-- Values are set by NexuLogging before the application and Spring Boot server start. -->
    <property name="NEXU_LOG_DIR" value="${NEXU_LOG_DIR:-${user.home}/.nexu/logs}"/>
    <property name="NEXU_LOG_LEVEL" value="${NEXU_LOG_LEVEL:-DEBUG}"/>
    <property name="NEXU_LOG_MAX_FILE_SIZE" value="${NEXU_LOG_MAX_FILE_SIZE:-10MB}"/>
    <property name="NEXU_LOG_MAX_HISTORY" value="${NEXU_LOG_MAX_HISTORY:-14}"/>
    <property name="NEXU_LOG_TOTAL_SIZE_CAP" value="${NEXU_LOG_TOTAL_SIZE_CAP:-200MB}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${NEXU_LOG_DIR}/nexu.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{48} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${NEXU_LOG_DIR}/archive/nexu.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${NEXU_LOG_MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${NEXU_LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${NEXU_LOG_TOTAL_SIZE_CAP}</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <logger name="lu.nowina" level="${NEXU_LOG_LEVEL}"/>
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.apache" level="INFO"/>
    <logger name="java.util.prefs" level="ERROR"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>

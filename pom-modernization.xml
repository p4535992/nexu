<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>lu.nowina.apps</groupId>
        <artifactId>nexu</artifactId>
        <version>1.24-SNAPSHOT</version>
        <relativePath>pom.xml</relativePath>
    </parent>

    <artifactId>nexu-modernization-reactor</artifactId>
    <packaging>pom</packaging>
    <name>NexU Spring Boot modernization reactor</name>

    <!--
      This reactor contains only modules that contribute to the modern local
      agent. The executable module keeps the historical name nexu-app.

      Legacy REST compatibility is part of nexu-spring-boot-server. The old
      Jetty multi-user request processor is not part of the Spring Boot runtime.

      The target layout is four Maven modules:
      core, card-drivers, local-server and nexu-app. Packaging remains build
      infrastructure under nexu-app rather than a separate Java module.
    -->
    <modules>
        <module>nexu-api</module>
        <module>nexu-model</module>
        <module>nexu-util</module>
        <module>nexu-core</module>
        <module>nexu-standalone</module>
        <module>nexu-windows-keystore-plugin</module>
        <module>nexu-spring-boot-server</module>
        <module>nexu-app</module>
    </modules>
</project>
